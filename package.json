{
  "name": "skillevel",
  "version": "0.1.0",
  "description": "A test runner for Claude Code skills — vitest for skills. Write YAML cases, run them through `claude -p`, and check that each skill triggers (and behaves) the way it should.",
  "type": "module",
  "bin": { "skillevel": "src/cli.js" },
  "scripts": {
    "start": "node src/cli.js",
    "typecheck": "tsc -p jsconfig.json"
  },
  "files": ["src"],
  "engines": { "node": ">=18" },
  "keywords": ["claude", "claude-code", "skills", "eval", "test-runner", "llm", "agent"],
  "license": "MIT",
  "dependencies": {
    "commander": "^12.1.0",
    "picocolors": "^1.1.1",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "typescript": "^5.6.3"
  }
}
